<%- include('header') %>

<% if (message) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    ✅ <%= message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<h2 class="mb-4">📊 Dashboard</h2>

<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card text-center border-success">
      <div class="card-body">
        <h3 class="text-success fw-bold"><%= total %></h3>
        <p class="mb-0">Total Books</p>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center border-primary">
      <div class="card-body">
        <h3 class="text-primary fw-bold"><%= available %></h3>
        <p class="mb-0">Available</p>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center border-danger">
      <div class="card-body">
        <h3 class="text-danger fw-bold"><%= outStock %></h3>
        <p class="mb-0">Out of Stock</p>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center border-warning">
      <div class="card-body">
        <h3 class="text-warning fw-bold"><%= genres %></h3>
        <p class="mb-0">Genres</p>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header bg-white d-flex justify-content-between align-items-center">
    <h5 class="mb-0">📋 All Books (<%= total %>)</h5>
    <a href="/add" class="btn btn-success btn-sm">+ Add New Book</a>
  </div>
  <div class="card-body p-0">
    <% if (books.length === 0) { %>
      <div class="text-center text-muted py-5">
        <h5>No books added yet!</h5>
        <a href="/add" class="btn btn-success mt-2">+ Add Your First Book</a>
      </div>
    <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover table-bordered mb-0">
        <thead class="table-light">
          <tr>
            <th>#ID</th>
            <th>Cover</th>
            <th>Title</th>
            <th>Author</th>
            <th class="d-none d-md-table-cell">Genre</th>
            <th>Price (₹)</th>
            <th>Status</th>
            <th class="text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% books.forEach(book => { %>
          <tr>
            <td><b>#<%= book.id %></b></td>
            <td>
              <% if (book.image) { %>
                <img
                  src="<%= book.image %>"
                  alt="cover"
                  style="width:50px; height:65px; object-fit:cover; border-radius:4px; border:1px solid #dee2e6; display:block;"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
                <div style="width:50px;height:65px;background:#e9ecef;border-radius:4px;display:none;align-items:center;justify-content:center;font-size:1.4rem;">📖</div>
              <% } else { %>
                <div style="width:50px;height:65px;background:#e9ecef;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;">📖</div>
              <% } %>
            </td>
            <td><b><%= book.title %></b></td>
            <td class="text-muted"><%= book.author %></td>
            <td class="d-none d-md-table-cell">
              <span class="badge bg-secondary"><%= book.genre %></span>
            </td>
            <td><b>₹<%= book.price %></b></td>
            <td>
              <% if (book.status === 'Available') { %>
                <span class="badge bg-success">✅ Available</span>
              <% } else { %>
                <span class="badge bg-danger">❌ Out of Stock</span>
              <% } %>
            </td>
            <td class="text-center">
              <form action="/status/<%= book.id %>" method="POST" class="d-inline">
                <button class="btn btn-sm btn-outline-secondary">🔄</button>
              </form>
              <a href="/edit/<%= book.id %>" class="btn btn-sm btn-outline-warning">✏️</a>
              <form action="/delete/<%= book.id %>" method="POST" class="d-inline"
                    onsubmit="return confirm('Delete this book?')">
                <button class="btn btn-sm btn-outline-danger">🗑️</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<%- include('footer') %>
